// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  guest
  admin
  reception
}

enum RoomType {
  premium
  premium_plus
}

enum RoomStatus {
  active
  maintenance
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  checked_in
  checked_out
}

enum BookingSource {
  online
  offline
}

enum PaymentMethod {
  UPI
  card
  cash
  gateway
}

enum PaymentStatus {
  yet_to_pay
  paid
  refunded
  cancelled
}

enum IdProofType {
  aadhaar
  passport
  driving_license
  voter_id
}

// ─── TABLE 1: Guests ──────────────────────────────────────

model Guest {
  id            Int          @id @default(autoincrement())
  fullName      String       @map("full_name")
  phone         String
  email         String?
  address       String?
  idProofType   IdProofType? @map("id_proof_type")
  createdAt     DateTime     @default(now()) @map("created_at")
  bookings      Booking[]

  @@index([phone])
  @@index([email])
  @@map("guests")
}

// ─── TABLE 2: Rooms ───────────────────────────────────────

model Room {
  id            Int        @id @default(autoincrement())
  roomNumber    String     @unique @map("room_number")
  roomType      RoomType   @map("room_type")
  maxGuests     Int        @map("max_guests")
  pricePerNight Decimal    @map("price_per_night") @db.Decimal(10, 2)
  status        RoomStatus @default(active)
  description   String?
  createdAt     DateTime   @default(now()) @map("created_at")

  bookingRooms  BookingRoom[]

  @@index([status])
  @@index([roomType])
  @@map("rooms")
}

// ─── TABLE 3: Bookings ────────────────────────────────────

model Booking {
  id               Int           @id @default(autoincrement())
  guestId          Int           @map("guest_id")
  bookingReference String?       @unique @map("booking_reference")
  checkIn          DateTime      @map("check_in") @db.Date
  checkOut         DateTime      @map("check_out") @db.Date
  totalGuests      Int           @map("total_guests")
  bookingStatus    BookingStatus @default(pending) @map("booking_status")
  bookingSource    BookingSource @map("booking_source")
  totalAmount      Decimal       @map("total_amount") @db.Decimal(10, 2)
  extraExpense     String?       @map("extra_expense")
  createdAt        DateTime      @default(now()) @map("created_at")

  guest            Guest         @relation(fields: [guestId], references: [id])
  bookingRooms     BookingRoom[]
  payments         Payment[]
  invoice          Invoice?

  @@index([guestId])
  @@index([checkIn, checkOut])
  @@index([bookingStatus])
  @@index([bookingReference])
  @@map("bookings")
}

// ─── TABLE 4: BookingRooms ────────────────────────────────

model BookingRoom {
  id        Int     @id @default(autoincrement())
  bookingId Int     @map("booking_id")
  roomId    Int     @map("room_id")

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room      Room    @relation(fields: [roomId], references: [id])

  @@unique([bookingId, roomId])
  @@index([bookingId])
  @@index([roomId])
  @@map("booking_rooms")
}

// ─── TABLE 5: Payments ────────────────────────────────────

model Payment {
  id            Int           @id @default(autoincrement())
  bookingId     Int           @map("booking_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(yet_to_pay) @map("payment_status")
  transactionId String?       @map("transaction_id")
  paymentDate   DateTime?     @map("payment_date")
  createdAt     DateTime      @default(now()) @map("created_at")

  booking       Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([paymentStatus])
  @@map("payments")
}

// ─── TABLE 6: Daily Counter ───────────────────────────────

model DailyCounter {
  date  String @id
  count Int    @default(0)
  @@map("daily_counters")
}

// ─── TABLE 7: Invoices ────────────────────────────────────

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String   @unique @map("invoice_number")
  bookingId     Int      @unique @map("booking_id")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("invoices")
}

//authentication

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("admin_users")
}