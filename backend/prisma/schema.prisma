// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────

enum Role {
  guest
  admin
  reception
}

enum RoomType {
  premium
  premium_plus
}

enum RoomStatus {
  active
  maintenance
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

enum BookingSource {
  online
  offline
}

enum PaymentMethod {
  UPI
  card
  cash
  gateway
}

enum PaymentStatus {
  pending
  completed
  failed
}

enum IdProofType {
  aadhaar
  passport
  driving_license
  voter_id
}

// ─── TABLE 1: Users ───────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String    @map("password_hash")
  role         Role      @default(guest)
  createdAt    DateTime  @default(now()) @map("created_at")

  bookings     Booking[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─── TABLE 2: Guests ──────────────────────────────────────

model Guest {
  id            Int          @id @default(autoincrement())
  fullName      String       @map("full_name")
  phone         String
  email         String?
  address       String?
  idProofType   IdProofType? @map("id_proof_type")   // stores: aadhaar / passport / etc.
  createdAt     DateTime     @default(now()) @map("created_at")
  members       GuestMember[]
  bookings      Booking[]

  @@index([phone])
  @@index([email])
  @@map("guests")
}

// ─── TABLE 3: GuestMembers ────────────────────────────────

model GuestMember {
  id         Int     @id @default(autoincrement())
  guestId    Int     @map("guest_id")
  memberName String  @map("member_name")
  age        Int?
  relation   String?

  guest      Guest   @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@map("guest_members")
}

// ─── TABLE 4: Rooms ───────────────────────────────────────

model Room {
  id            Int        @id @default(autoincrement())
  roomNumber    String     @unique @map("room_number")
  roomType      RoomType   @map("room_type")
  maxGuests     Int        @map("max_guests")
  pricePerNight Decimal    @map("price_per_night") @db.Decimal(10, 2)
  status        RoomStatus @default(active)
  description   String?
  createdAt     DateTime   @default(now()) @map("created_at")

  bookingRooms  BookingRoom[]

  @@index([status])
  @@index([roomType])
  @@map("rooms")
}

// ─── TABLE 5: Bookings ────────────────────────────────────

model Booking {
  id            Int           @id @default(autoincrement())
  guestId       Int           @map("guest_id")
  userId        Int?          @map("user_id")
  checkIn       DateTime      @map("check_in") @db.Date
  checkOut      DateTime      @map("check_out") @db.Date
  totalGuests   Int           @map("total_guests")
  bookingStatus BookingStatus @default(pending) @map("booking_status")
  bookingSource BookingSource @map("booking_source")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  guest         Guest         @relation(fields: [guestId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])
  bookingRooms  BookingRoom[]
  payments      Payment[]

  @@index([guestId])
  @@index([userId])
  @@index([checkIn, checkOut])
  @@index([bookingStatus])
  @@map("bookings")
}

// ─── TABLE 6: BookingRooms ────────────────────────────────

model BookingRoom {
  id        Int     @id @default(autoincrement())
  bookingId Int     @map("booking_id")
  roomId    Int     @map("room_id")

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room      Room    @relation(fields: [roomId], references: [id])

  @@unique([bookingId, roomId])
  @@index([bookingId])
  @@index([roomId])
  @@map("booking_rooms")
}

// ─── TABLE 7: Payments ────────────────────────────────────

model Payment {
  id            Int           @id @default(autoincrement())
  bookingId     Int           @map("booking_id")
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  transactionId String?       @map("transaction_id")
  paymentDate   DateTime?     @map("payment_date")
  createdAt     DateTime      @default(now()) @map("created_at")

  booking       Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([paymentStatus])
  @@map("payments")
}